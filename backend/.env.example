APP_NAME="Vanessa Perfumes"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# Maintenance Mode
APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP CLI Server Workers
# PHP_CLI_SERVER_WORKERS=4

# Security
BCRYPT_ROUNDS=12

# Logging
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database - XAMPP MySQL Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=vanessa_perfumes
DB_USERNAME=root
DB_PASSWORD=

# Session Configuration
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=null
SESSION_SAME_SITE=lax

# CORS Configuration (SECURITY CRITICAL)
# Production: Set CORS_ALLOWED_ORIGINS to your explicit frontend domain(s)
# NEVER use wildcard (*) when CORS_SUPPORTS_CREDENTIALS=true
CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGINS_DEV=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
CORS_ALLOWED_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With,X-CSRF-TOKEN,Accept,Origin,X-XSRF-TOKEN
CORS_SUPPORTS_CREDENTIALS=true
CORS_MAX_AGE=1728000

# Sanctum Configuration (for SPA cookie-based authentication)
# Set to your frontend domain(s) - comma separated
SANCTUM_STATEFUL_DOMAINS=localhost,localhost:3000,localhost:3001,127.0.0.1,127.0.0.1:8000

# Broadcasting & Cache
BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database
# CACHE_PREFIX=

# Memcached
MEMCACHED_HOST=127.0.0.1

# Redis Configuration
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Mail Configuration
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@vanessaperfumes.com"
MAIL_FROM_NAME="${APP_NAME}"

# AWS S3 (for production file storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Payment Gateway Configuration (Stripe)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
AUTH_RATE_LIMIT_ATTEMPTS=5
AUTH_RATE_LIMIT_DECAY=1

# API Configuration
API_VERSION=v1
API_DEFAULT_PER_PAGE=15
API_MAX_PER_PAGE=100

# Health Check
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_TIMEOUT=5
HEALTH_CHECK_DETAILS=false

# Product Cache Configuration
PRODUCT_CACHE_ENABLED=true
PRODUCT_CACHE_TTL=3600

# Audit Logging Configuration
ACTIVITY_LOGGER_ENABLED=true
ACTIVITY_LOGGER_RETENTION_DAYS=365
ACTIVITY_LOGGER_TABLE_NAME=activity_log

# Sentry Error Monitoring
SENTRY_LARAVEL_DSN=
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_RELEASE=
SENTRY_SAMPLE_RATE=1.0
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.1
SENTRY_SEND_DEFAULT_PII=false

# Security Headers Configuration
HSTS_ENABLED=false
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=false
CSP_REPORT_URI=
FRAME_ANCESTORS=DENY
SECURITY_HEADERS_MODE=moderate
