# =============================================================================
# Docker Ignore File
# =============================================================================
# Prevents unnecessary files from being sent to Docker build context
# This speeds up builds and keeps images smaller
# =============================================================================

# -----------------------------------------------------------------------------
# Git
# -----------------------------------------------------------------------------
.git
.gitignore
.gitattributes
.gitmodules

# -----------------------------------------------------------------------------
# IDE & Editor Files
# -----------------------------------------------------------------------------
.idea
.vscode
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.sublime-project
*.sublime-workspace
.phpstorm.meta.php
_ide_helper.php
_ide_helper_models.php

# -----------------------------------------------------------------------------
# Environment Files (Sensitive)
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.docker.example
.env.local
.env.testing
.env.backup

# -----------------------------------------------------------------------------
# Dependencies (Installed via Composer/NPM in container)
# -----------------------------------------------------------------------------
backend/vendor
backend/node_modules
frontend/node_modules

# -----------------------------------------------------------------------------
# Build & Cache Directories
# -----------------------------------------------------------------------------
frontend/.next
frontend/out
frontend/dist
frontend/build
frontend/*.tsbuildinfo
frontend/next-env.d.ts

# -----------------------------------------------------------------------------
# Testing
# -----------------------------------------------------------------------------
backend/phpunit.result.cache
backend/.phpunit.result.cache
backend/coverage
backend/tests/coverage
.nyc_output
coverage

# -----------------------------------------------------------------------------
# Documentation
# -----------------------------------------------------------------------------
# (Keep README.md for project documentation)

# -----------------------------------------------------------------------------
# Docker (Don't include Docker files in context)
# -----------------------------------------------------------------------------
# Note: We DO need docker/ folder for builds, but not these:
docker-compose.override.yml

# -----------------------------------------------------------------------------
# CI/CD
# -----------------------------------------------------------------------------
.github
.gitlab-ci.yml
.travis.yml
.circleci
Jenkinsfile

# -----------------------------------------------------------------------------
# Logs
# -----------------------------------------------------------------------------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -----------------------------------------------------------------------------
# Temporary Files
# -----------------------------------------------------------------------------
tmp
temp
*.tmp
*.temp
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Backup Files
# -----------------------------------------------------------------------------
*.sql
*.sql.gz
*.dump
*.backup
*.bak

# -----------------------------------------------------------------------------
# OS Generated
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.tgz
*.tar.gz
*.zip
*.rar
*.7z
