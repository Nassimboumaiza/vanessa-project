# =============================================================================
# Frontend Docker Ignore
# =============================================================================
# Files and directories to exclude from Docker build context
# This reduces build time and image size
# =============================================================================

# Git
.git
.gitignore
.gitattributes

# IDE
.idea
.vscode
*.swp
*.swo
*~

# OS
.DS_Store
Thumbs.db

# Dependencies
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage/
.nyc_output/
*.test.ts
*.test.tsx
*.spec.ts
*.spec.tsx
tests/
__tests__/
jest.config.js
jest.config.ts
vitest.config.ts

# Build outputs
.next/
out/
dist/
build/

# Environment files
.env
.env.local
.env.development
.env.production
.env.test
.env.*.local

# Documentation
README.md
CHANGELOG.md
LICENSE.md
*.md

# CI/CD
.github/
.github/workflows/

# Docker
Dockerfile*
docker-compose*.yml
.docker/
.dockerignore

# Backend (separate container)
../backend/

# Logs
*.log

# Temporary files
tmp/
temp/
*.tmp
*.temp

# Misc
.editorconfig
.prettierrc
.prettierignore
.eslintrc*
.eslintignore
postcss.config.*
